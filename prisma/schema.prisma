generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String        @id @default(uuid())
  email            String        @unique
  password         String
  name             String
  role             String        @default("STAFF") // DIRECTOR, ADMIN, PROJECT_MANAGER, MANAGER, CAREHOME_MANAGER, STAFF
  tasks            Task[]        @relation("TaskOwner")
  submittedTasks   Task[]        @relation("TaskSubmitter")
  spaceMemberships SpaceMember[]
}

model Phase {
  id      String  @id @default(uuid())
  name    String
  order   Int
  tasks   Task[]
  spaceId String?
  space   Space?  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
}

model Task {
  id             String   @id @default(uuid())
  actionItem     String
  priority       String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  status         String   @default("NOT_STARTED") // COMPLETE, NOT_STARTED, IN_PROGRESS, ON_HOLD
  startDate      DateTime?
  dueDate        DateTime?
  durationDays   Int      @default(0)
  actualDays     Int?     @default(0)
  actualEndDate  DateTime?
  variance       String?
  evidence       String?
  actionType     String?
  ragRating      String?  @default("GREEN") // RED, AMBER, GREEN
  completedBy    String?
  accepted       Boolean  @default(false)
  submittedById  String?
  submittedBy    User?    @relation("TaskSubmitter", fields: [submittedById], references: [id])
  ownerId        String?
  owner          User?    @relation("TaskOwner", fields: [ownerId], references: [id])
  phaseId        String
  phase          Phase    @relation(fields: [phaseId], references: [id])
  spaceId        String?
  space          Space?   @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  resources      String?
  estimatedCost  Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Space {
  id        String        @id @default(uuid())
  name      String
  createdAt DateTime      @default(now())
  members   SpaceMember[]
  phases    Phase[]
  tasks     Task[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model SpaceMember {
  id      String @id @default(uuid())
  userId  String
  spaceId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([userId, spaceId])
}
